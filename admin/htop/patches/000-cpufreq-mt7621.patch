+static double getDynamicCPUFrequency(void) {
+   double freqMHz = NAN;
+   FILE* clkFile = fopen("/sys/kernel/debug/clk/clk_dump", "r");
+   if (clkFile == NULL)
+      return freqMHz;
+
+   char* line = NULL;
+   size_t len = 0;
+
+   if (getline(&line, &len, clkFile) != -1) {
+      char* cpuPos = strstr(line, "\"cpu\"");
+      if (cpuPos != NULL) {
+         char* ratePos = strstr(cpuPos, "\"rate\"");
+         if (ratePos != NULL) {
+            unsigned long long rateHz = 0;
+            if (sscanf(ratePos, "\"rate\": %llu", &rateHz) == 1) {
+               if (rateHz > 0) {
+                  freqMHz = (double)rateHz / 1000000.0;
+               }
+            }
+         }
+      }
+   }
+
+   free(line);
+   fclose(clkFile);
+   return freqMHz;
+}
